# Local development (Gemini API / AI Studio)
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=PASTE_YOUR_GOOGLE_API_KEY
AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Optional local voice mode model (Gemini Live API):
# AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Cloud Run production (Vertex Live API):
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# AGENT_MODEL=gemini-live-2.5-flash-native-audio

# Optional: pin playback to a specific Spotify device for reliability.
# SPOGO_DEVICE_ID=your_spotify_device_id
